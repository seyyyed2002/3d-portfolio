{
  "name": "prayer-tracker",
  "version": "1.0.0",
  "description": "A single-page application for tracking daily reading of religious texts",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "build": "cd frontend && npm run build",
    "start": "./start.sh"
  },
  "keywords": ["prayer", "tracker", "vue", "node", "mongodb", "religious"],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}